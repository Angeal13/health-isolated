# ╔══════════════════════════════════════════════════════════════╗
# ║  BIOKO HEALTH — Nodo Provincial Annobón                      ║
# ║                                                              ║
# ║  ⚠️  CONECTIVIDAD A DEFINIR CON EL MINISTERIO                ║
# ║  Opciones (ver ANNOBON_SYNC_MODE):                           ║
# ║    weekly    : sync semanal automático (requiere internet)   ║
# ║    manual    : sync manual via USB o cuando hay conexión     ║
# ║    satellite : conexión satelital (coste adicional)          ║
# ║                                                              ║
# ║  Por defecto: weekly — sync domingo a las 03:00 AM           ║
# ║  cuando haya conexión disponible.                            ║
# ╚══════════════════════════════════════════════════════════════╝

FLASK_ENV=annobon_node
SECRET_KEY=GENERAR-CON-python3-c-import-secrets-print-secrets-token-hex-32
DATABASE_URL=mysql+pymysql://bioko_user:PASSWORD_LOCAL@localhost/bioko_health

# Identidad
FACILITY_CODE=NODO-ANNOBON
FACILITY_NAME=Nodo Provincial Annobon — San Antonio de Pale
FACILITY_TYPE=nodo_provincial
FACILITY_MODE=annobon_node
PROVINCIA_CODIGO=AN

# Red local de Annobon (LAN interna de la isla)
LAN_HOST=0.0.0.0
LAN_PORT=5000
LAN_URL=http://192.168.100.10:5000

# Intranet local de Annobon (instalaciones de la isla)
INTRANET_MODE=true
INTRANET_PULL_INTERVAL=300

# Modo de sync con el central - DEFINIR CON MINISTERIO
# weekly   = sync automatico cuando haya internet (cada domingo 03:00)
# manual   = solo sync cuando el operador lo active manualmente
# satellite = conexion satelital continua (presupuesto adicional)
ANNOBON_SYNC_MODE=weekly

# Sync con servidor central (internet - intermitente)
SYNC_ENABLED=true
CENTRAL_SERVER_URL=https://central.biokohealth.gq
SYNC_API_TOKEN=TOKEN-COMPARTIDO-TODA-LA-RED
SYNC_HOUR=3
SYNC_MINUTE=0

# Cache de expedientes de otras provincias
# Mayor tiempo de cache porque la conexion es intermitente
CACHE_EXPEDIENTE_DIAS=90

# URLs de nodos provinciales para transferencias
# (solo accesibles cuando hay conexion internet disponible)
NODO_BIOKO_URL=https://central.biokohealth.gq/provincial-bioko
NODO_LITORAL_URL=https://central.biokohealth.gq/provincial-litoral

DB_POOL_SIZE=15
DB_POOL_OVERFLOW=20
OUTBREAK_THRESHOLD=3
